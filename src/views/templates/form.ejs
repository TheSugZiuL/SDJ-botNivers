<%- include("../partials/header", { pageTitle, currentPath, flashOk, flashErr }) %>

<section class="card form-card">
  <h3><%= formMode === 'edit' ? 'Editar Template' : 'Novo Template' %></h3>

  <% if (errors && errors.length) { %>
    <div class="alert error">
      <ul class="error-list">
        <% errors.forEach(function(err) { %>
          <li><%= err %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form method="post" action="<%= formMode === 'edit' ? '/templates/' + item.id : '/templates' %>" class="stack-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label for="tipo">Tipo do template *</label>
    <select id="tipo" name="tipo" required>
      <option value="birthday_today" <%= item.tipo === 'birthday_today' ? 'selected' : '' %>>Aniversario (dia atual)</option>
      <option value="birthday_reminder_d5" <%= item.tipo === 'birthday_reminder_d5' ? 'selected' : '' %>>Lembrete D-5</option>
      <option value="birthday_reminder_d3" <%= item.tipo === 'birthday_reminder_d3' ? 'selected' : '' %>>Lembrete D-3</option>
      <option value="birthday_reminder_d1" <%= item.tipo === 'birthday_reminder_d1' ? 'selected' : '' %>>Lembrete D-1 (amanha)</option>
    </select>

    <label for="nome">Nome do template *</label>
    <input id="nome" name="nome" type="text" required maxlength="80" value="<%= item.nome || '' %>" />

    <label for="conteudo">Mensagem *</label>
    <textarea id="conteudo" name="conteudo" rows="8" required><%= item.conteudo || 'Hoje e aniversario de {nome} ({dia}/{mes})! Parabens! Que seu dia seja incrivel!' %></textarea>

    <p class="hint">
      Placeholders: <code>{nome}</code>, <code>{observacao}</code>, <code>{dia}</code>, <code>{mes}</code>,
      <code>{dias_faltam}</code> (somente lembrete).
    </p>

    <label class="checkbox-row">
      <input type="checkbox" name="ativo" <%= Number(item.ativo) ? 'checked' : '' %> />
      Definir como ativo
    </label>

    <div class="actions-row">
      <button type="submit" class="btn">Salvar</button>
      <a class="btn btn-outline" href="/templates">Cancelar</a>
    </div>
  </form>
</section>

<%- include("../partials/footer") %>
